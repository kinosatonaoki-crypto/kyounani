{
  "version": 2,
  "builds": [
    {
      "src": "api/comment.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.json",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "icons/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/comment",
      "dest": "/api/comment.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
